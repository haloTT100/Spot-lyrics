<Window x:Class="lyrics_overlay.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:lyrics_overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="CanResizeWithGrip"
        MinWidth="320"
        MinHeight="120">
    <Window.Resources>
        <local:LineOpacityConverter x:Key="LineOpacityConverter"/>
        <local:LineFontSizeConverter x:Key="LineFontSizeConverter"/>
        <local:LineWeightConverter x:Key="LineWeightConverter"/>
    </Window.Resources>

    <Border x:Name="OverlayBorder"
            Background="#66000000"
            BorderBrush="#44FFFFFF"
            BorderThickness="1"
            CornerRadius="14"
            Padding="18"
            SnapsToDevicePixels="True">
        <Grid>
            <ItemsControl x:Name="LyricsItemsControl"
                          ItemsSource="{Binding VisibleLyrics}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel VerticalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}"
                                TextAlignment="Center"
                                TextWrapping="Wrap"
                                Margin="0,4"
                                Foreground="White"
                                Opacity="{Binding DistanceFromCurrent, Converter={StaticResource LineOpacityConverter}}"
                                FontSize="{Binding DistanceFromCurrent, Converter={StaticResource LineFontSizeConverter}}"
                                FontWeight="{Binding DistanceFromCurrent, Converter={StaticResource LineWeightConverter}}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Black"
                                                ShadowDepth="0"
                                                BlurRadius="2"
                                                Opacity="1"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>
    </Border>
</Window>